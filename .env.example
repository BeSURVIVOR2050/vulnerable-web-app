# Copy to ".env" before running docker compose (never commit .env).
# Keep DB_PASSWORD identical to MYSQL_ROOT_PASSWORD for this stack.

# --- Images: prefer pinned patch tags in real deployments; verify on Docker Hub before pinning ---
# https://hub.docker.com/_/php   https://hub.docker.com/_/mysql
PHP_IMAGE=php:8.2-cli-bookworm
MYSQL_IMAGE=mysql:8.0

# --- Published ports: bind loopback only (reduces exposure on LAN/shared hosts) ---
APP_BIND=127.0.0.1
# Change if 8080 is already in use on your machine (e.g. 8081).
# In docker-compose.host-network.yml, APP_PORT is also the port PHP binds on the host.
APP_PORT=8080
MYSQL_BIND=127.0.0.1
MYSQL_PORT=3307

# --- MySQL server (official image variables) ---
MYSQL_ROOT_PASSWORD=P@ssw0rd
MYSQL_DATABASE=secure_db

# --- PHP mysqli (must match database credentials above) ---
DB_USER=root
DB_PASSWORD=P@ssw0rd
DB_NAME=secure_db
